# Provider: github or gitflic
PROVIDER=gitflic

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=owner/repo_name

# GitFlic Configuration
GITFLIC_TOKEN=your_gitflic_token_here
GITFLIC_PROJECT=owner/project_name

# Output directory (optional, defaults to data/projects/issues)
ISSUES_DIR=data/projects/issues
