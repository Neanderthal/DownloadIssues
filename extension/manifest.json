{
  "manifest_version": 3,
  "name": "DT Encrypted Transfer",
  "version": "1.0.0",
  "description": "Push/pull encrypted files via GitHub/GitFlic issues",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:9741/*",
    "https://api.github.com/*",
    "https://api.gitflic.ru/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
